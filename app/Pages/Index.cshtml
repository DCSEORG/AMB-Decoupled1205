@page
@model ExpenseManagement.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

@if (Model.ErrorMessage != null)
{
    <div class="error-banner">
        <strong>⚠️ Database Error:</strong> @Model.ErrorMessage
    </div>
}

<div class="page-container">
    <div class="page-header">
        <h1>Expense Dashboard</h1>
        <a href="/Expenses/Create" class="btn btn-primary">+ New Expense</a>
    </div>

    <!-- Summary Cards -->
    <div class="summary-grid">
        @foreach (var s in Model.Summary)
        {
            <div class="summary-card status-@s.StatusName.ToLower()">
                <div class="summary-count">@s.Count</div>
                <div class="summary-label">@s.StatusName</div>
                <div class="summary-amount">£@s.TotalAmount.ToString("N2")</div>
            </div>
        }
    </div>

    <!-- Quick Actions -->
    <div class="quick-actions">
        <h2>Quick Actions</h2>
        <div class="action-grid">
            <a href="/Expenses?statusId=2" class="action-card">
                <span class="action-icon">📋</span>
                <span>Pending Approval</span>
            </a>
            <a href="/Expenses?statusId=1" class="action-card">
                <span class="action-icon">📝</span>
                <span>My Drafts</span>
            </a>
            <a href="/Expenses?statusId=3" class="action-card">
                <span class="action-icon">✅</span>
                <span>Approved</span>
            </a>
            <a href="/Expenses?statusId=4" class="action-card">
                <span class="action-icon">❌</span>
                <span>Rejected</span>
            </a>
            <a href="/Expenses" class="action-card">
                <span class="action-icon">📊</span>
                <span>All Expenses</span>
            </a>
            <a href="/swagger" class="action-card" target="_blank">
                <span class="action-icon">🔌</span>
                <span>API Docs</span>
            </a>
        </div>
    </div>

    <!-- Recent Expenses -->
    <div class="section-card">
        <h2>Recent Expenses</h2>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Employee</th>
                    <th>Category</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var expense in Model.RecentExpenses)
                {
                    <tr>
                        <td>@expense.ExpenseDate.ToString("dd MMM yyyy")</td>
                        <td>@expense.UserName</td>
                        <td>@expense.CategoryName</td>
                        <td>£@expense.AmountDecimal.ToString("N2")</td>
                        <td><span class="badge badge-@expense.StatusName.ToLower()">@expense.StatusName</span></td>
                        <td>
                            <a href="/Expenses/Details/@expense.ExpenseId" class="btn btn-sm btn-outline">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="table-footer">
            <a href="/Expenses" class="btn btn-outline">View All Expenses →</a>
        </div>
    </div>
</div>
