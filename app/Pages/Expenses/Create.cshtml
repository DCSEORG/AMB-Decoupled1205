@page "/Expenses/Create"
@model ExpenseManagement.Pages.Expenses.CreateModel
@{
    ViewData["Title"] = "New Expense";
}

@if (Model.ErrorMessage != null)
{
    <div class="error-banner">
        <strong>⚠️ Error:</strong> @Model.ErrorMessage
    </div>
}

<div class="page-container">
    <div class="page-header">
        <h1>New Expense</h1>
        <a href="/Expenses" class="btn btn-outline">← Back to Expenses</a>
    </div>

    <div class="section-card form-card">
        <form method="post">
            <div class="form-grid">
                <div class="form-group">
                    <label for="UserId">Employee *</label>
                    <select id="UserId" name="UserId" class="form-select" required>
                        <option value="">Select employee...</option>
                        @foreach (var user in Model.Users)
                        {
                            <option value="@user.UserId">@user.UserName</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label for="CategoryId">Category *</label>
                    <select id="CategoryId" name="CategoryId" class="form-select" required>
                        <option value="">Select category...</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.CategoryId">@cat.CategoryName</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label for="AmountGBP">Amount (£) *</label>
                    <input type="number" id="AmountGBP" name="AmountGBP" class="form-input"
                           step="0.01" min="0.01" placeholder="0.00" required />
                </div>
                <div class="form-group">
                    <label for="ExpenseDate">Date *</label>
                    <input type="date" id="ExpenseDate" name="ExpenseDate" class="form-input"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                </div>
                <div class="form-group form-group-full">
                    <label for="Description">Description</label>
                    <textarea id="Description" name="Description" class="form-textarea" rows="3"
                              placeholder="What was this expense for?"></textarea>
                </div>
                <div class="form-group form-group-full">
                    <label for="ReceiptFile">Receipt Reference</label>
                    <input type="text" id="ReceiptFile" name="ReceiptFile" class="form-input"
                           placeholder="e.g. /receipts/invoice-001.pdf" />
                </div>
                <div class="form-group">
                    <label for="StatusId">Save as</label>
                    <select id="StatusId" name="StatusId" class="form-select">
                        <option value="1">Draft</option>
                        <option value="2">Submit for Approval</option>
                    </select>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save Expense</button>
                <a href="/Expenses" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
