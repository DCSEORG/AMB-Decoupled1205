@page "/Expenses/Edit/{id:int}"
@model ExpenseManagement.Pages.Expenses.EditModel
@{
    ViewData["Title"] = "Edit Expense";
}

@if (Model.ErrorMessage != null)
{
    <div class="error-banner">
        <strong>⚠️ Error:</strong> @Model.ErrorMessage
    </div>
}

<div class="page-container">
    <div class="page-header">
        <h1>Edit Expense #@Model.Expense?.ExpenseId</h1>
        <a href="/Expenses/Details/@Model.Expense?.ExpenseId" class="btn btn-outline">← Back</a>
    </div>

    @if (Model.Expense != null)
    {
        <div class="section-card form-card">
            <form method="post">
                <input type="hidden" name="id" value="@Model.Expense.ExpenseId" />
                <div class="form-grid">
                    <div class="form-group">
                        <label for="CategoryId">Category *</label>
                        <select id="CategoryId" name="CategoryId" class="form-select" required>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.CategoryId" selected="@(Model.Expense.CategoryId == cat.CategoryId ? "selected" : null)">
                                    @cat.CategoryName
                                </option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="AmountGBP">Amount (£) *</label>
                        <input type="number" id="AmountGBP" name="AmountGBP" class="form-input"
                               step="0.01" min="0.01" value="@Model.Expense.AmountDecimal" required />
                    </div>
                    <div class="form-group">
                        <label for="ExpenseDate">Date *</label>
                        <input type="date" id="ExpenseDate" name="ExpenseDate" class="form-input"
                               value="@Model.Expense.ExpenseDate.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="form-group form-group-full">
                        <label for="Description">Description</label>
                        <textarea id="Description" name="Description" class="form-textarea" rows="3">@Model.Expense.Description</textarea>
                    </div>
                    <div class="form-group form-group-full">
                        <label for="ReceiptFile">Receipt Reference</label>
                        <input type="text" id="ReceiptFile" name="ReceiptFile" class="form-input"
                               value="@Model.Expense.ReceiptFile" />
                    </div>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a href="/Expenses/Details/@Model.Expense.ExpenseId" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    }
</div>
